{
  "name": "ward-tools",
  "version": "0.0.2",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -n app,functions -c green,blue \"ng serve ward-tools --port 4201\" \"wrangler dev --local\"",
    "start:app": "ng serve ward-tools --port 4201",
    "start:functions": "wrangler dev --local",
    "build": "ng build --configuration production",
    "build-experimental": "ng build --configuration production && npm run post-build.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "gen-types": "supabase gen types typescript --project-id bfozbjjsbwakbucgdpao > database.d.ts",
    "gen-icon-codes": "npm run src/app/shared/icon/gen-icon-codes.ts",
    "update-angular": "npm i @angular/cdk @angular/common @angular/core @angular/forms @angular/platform-browser @angular/router @angular/service-worker @angular/build @angular/cli @angular/compiler @angular/compiler-cli @angular/language-service -f"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/service-worker": "^21.2.5",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@supabase/supabase-js": "^2.100.0",
    "install": "^0.13.0",
    "pdf-lib": "^1.17.1",
    "playwright-cli": "^0.262.0",
    "quill": "^2.0.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/language-service": "^21.2.5",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260315.1",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "supabase": "^2.83.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}
